
CC = gcc
CFLAGS = -Wall -Wextra -O2 -I./src
AR = ar
ARFLAGS = rcs

# Директории
SRC_DIR = src
TEST_DIR = tests
LIB_DIR = lib

# Исходные файлы
SRCS = $(SRC_DIR)/Galua_Field_256.c
OBJS = $(SRCS:.c=.o)
LIBRARY = $(LIB_DIR)/libgalua.a

# Цели по умолчанию
.PHONY: all clean lib tests check valgrind help

all: lib tests

# Создание директории для библиотеки
$(LIB_DIR):
	mkdir -p $(LIB_DIR)

# Сборка статической библиотеки
$(LIBRARY): $(OBJS) | $(LIB_DIR)
	$(AR) $(ARFLAGS) $@ $^

lib: $(LIBRARY)

# Сборка объектных файлов
$(SRC_DIR)/%.o: $(SRC_DIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# Запуск тестов
tests:
	$(MAKE) -C $(TEST_DIR)

check: tests
	$(MAKE) -C $(TEST_DIR) run

# Проверка памяти с Valgrind
valgrind: tests
	$(MAKE) -C $(TEST_DIR) valgrind

# Очистка
clean:
	rm -f $(OBJS)
	rm -rf $(LIB_DIR)
	$(MAKE) -C $(TEST_DIR) clean

# Информация
help:
	@echo "Доступные цели:"
	@echo "  all      - собрать библиотеку и тесты (по умолчанию)"
	@echo "  lib      - собрать только статическую библиотеку"
	@echo "  tests    - собрать тесты"
	@echo "  check    - собрать и запустить тесты"
	@echo "  clean    - очистить все собранные файлы"
	@echo "  help     - показать эту справку"